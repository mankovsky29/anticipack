@page "/edit-packing/{id}"

<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation" />

<div class="page-container with-fixed-navbar">
    <!-- Unified Activity Panel -->
    <div class="settings-panel @(_isSettingsExpanded ? "expanded" : "collapsed")" role="banner" aria-label="@AppResources.PackingActivity">
        <div class="settings-header" @onclick="ToggleSettings" @onclick:stopPropagation>
            <div class="settings-summary">
                <button class="icon-btn play header-play-btn" @onclick="SwitchToPackingMode" @onclick:stopPropagation aria-label="@AppResources.StartPacking">
                    <i class="fa fa-play" aria-hidden="true"></i>
                </button>
                <span class="activity-name-summary">@(_activityName ?? AppResources.NewPackingActivity)</span>
                <div class="header-right-actions">
                    @if (!_isSettingsExpanded)
                    {
                        <div class="settings-badges">
                            @if (_currentActivity.IsRecurring)
                            {
                                <span class="badge badge-recurring">
                                    <i class="fa fa-sync-alt"></i>
                                    <span>@Localizer["RecurringActivity"]</span>
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-one-time">
                                    <i class="fa fa-calendar-check"></i>
                                    <span>@Localizer["OneTimeActivity"]</span>
                                </span>
                            }
                            @if (_currentActivity.IsArchived)
                            {
                                <span class="badge badge-archived">
                                    <i class="fa fa-archive"></i>
                                    <span>@Localizer["Archived"]</span>
                                </span>
                            }
                        </div>
                    }
                    <div class="actions-overflow" @onclick:stopPropagation>
                        <button class="overflow-btn" @onclick="ToggleOverflowMenuAsync" @onclick:stopPropagation title="@AppResources.PackingDialogMenu">
                            <i class="fa fa-ellipsis-v" aria-hidden="true"></i>
                        </button>
                        @if (_isOverflowMenuOpen)
                        {
                            <div class="action-dropdown" role="menu">
                                <button class="dropdown-item" @onclick="CopyPacking" @onclick:stopPropagation role="menuitem">
                                    <i class="fa fa-copy" aria-hidden="true"></i>
                                    <span>@AppResources.CopyTitle</span>
                                </button>
                                <button class="dropdown-item delete-item" @onclick="PromptDeleteActivity" @onclick:stopPropagation role="menuitem">
                                    <i class="fa fa-trash" aria-hidden="true"></i>
                                    <span>@AppResources.DeleteActivity</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (_isSettingsExpanded)
        {
            <div class="settings-content">
                <!-- Activity Name -->
                <div class="setting-row">
                    <label for="activity-name-input" class="setting-label">
                        <i class="fa fa-tag"></i>
                        @Localizer["Name"]
                    </label>
                    <input id="activity-name-input"
                           type="text"
                           class="setting-input"
                           @bind="_activityName"
                           @bind:event="oninput"
                           @onblur="SaveActivityNameAsync"
                           @onclick:stopPropagation
                           placeholder="@AppResources.EnterActivityName" />
                </div>

                <!-- Activity Type -->
                <div class="setting-row">
                    <label class="setting-label">
                        <i class="fa fa-repeat"></i>
                        @Localizer["ActivityType"]
                    </label>
                    <div class="segmented-control">
                        <button class="segment @(_currentActivity.IsRecurring ? "active" : "")"
                                @onclick="() => SetActivityType(true)"
                                @onclick:stopPropagation
                                type="button">
                            <i class="fa fa-sync-alt"></i>
                            <span>@Localizer["RecurringActivity"]</span>
                        </button>
                        <button class="segment @(!_currentActivity.IsRecurring ? "active" : "")"
                                @onclick="() => SetActivityType(false)"
                                @onclick:stopPropagation
                                type="button">
                            <i class="fa fa-calendar-check"></i>
                            <span>@Localizer["OneTimeActivity"]</span>
                        </button>
                    </div>
                </div>

                <!-- Archive Toggle -->
                <div class="setting-row">
                    <label class="setting-label">
                        <i class="fa fa-archive"></i>
                        @Localizer["Archive"]
                    </label>
                    <label class="toggle-switch">
                        <input type="checkbox"
                               @bind="_currentActivity.IsArchived"
                               @bind:after="SaveArchiveStatusAsync"
                               @onclick:stopPropagation />
                        <span class="toggle-slider"></span>
                        <span class="toggle-label">@(_currentActivity.IsArchived ? Localizer["Archived"] : Localizer["Active"])</span>
                    </label>
                </div>
            </div>
        }
    </div>

    <main class="content-area">
        @if (_isLoading)
        {
            <div class="loading">
                <div class="loading-spinner"></div>
                <span>@AppResources.LoadingPacking</span>
            </div>
        }

        <div class="packing-list">
            @if (!Items.Any() && !_isAddingItem)
            {
                <!-- Empty state: Show add button when no items exist -->
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="fa fa-box-open"></i>
                    </div>
                    <p class="empty-state-text">@Localizer["NoItemsYet"]</p>
                    <button class="btn btn-primary" @onclick="ShowAddItemForm">
                        <i class="fa fa-plus"></i>
                        <span>@Localizer["AddFirstItem"]</span>
                    </button>
                </div>
            }

            @foreach (var category in _categoryOrder)
            {
                var groupItems = Items.Where(i => string.Equals(i.Item.Category, category, StringComparison.OrdinalIgnoreCase)).ToList();
                if (!groupItems.Any())
                    continue;

                var allChecked = IsAllChecked(category);
                var collapsed = IsCollapsed(category);
                var categoryId = $"cat-{category}";
                var localizedCategory = GetLocalizedCategoryName(category);

                <section class="category @(allChecked ? "category-completed" : "")" aria-labelledby="@categoryId">
                    <div class="category-header" role="button" @onclick="() => ToggleCategory(category)" aria-expanded="@(!collapsed)">
                        <span class="chev @(collapsed ? "collapsed" : "")" aria-hidden="true">
                            <i class="fa fa-chevron-down"></i>
                        </span>
                        <h4 id="@categoryId" class="category-title @(allChecked ? "checked" : "")">
                            @localizedCategory <span class="count">(@groupItems.Count)</span>
                        </h4>
                        <button class="category-add-btn" 
                                @onclick="() => ShowAddItemFormForCategory(category)" 
                                @onclick:stopPropagation
                                title="@AppResources.AddItem">
                            <i class="fa fa-plus"></i>
                        </button>
                    </div>

                    <ul class="category-content @(collapsed ? "hidden" : "")">
                        @foreach (var item in groupItems)
                        {
                            var itemId = $"item-{item.Item.Id}";
                            <li class="@GetPackingRowClass(item)"
                                id="@itemId"
                                draggable="true"
                                @ondragstart="@((DragEventArgs e) => OnDragStart(e, item))"
                                @ondragend="@((DragEventArgs e) => OnDragEnd(e, item))"
                                @ondragover:preventDefault
                                @ondragover="@(async (DragEventArgs e) => await OnDragOver(e, item))"
                                @ondragenter:preventDefault
                                @ondragenter="@((DragEventArgs e) => OnDragEnter(e, item))"
                                @ondragleave="@((DragEventArgs e) => OnDragLeave(e, item))"
                                @ondrop:preventDefault
                                @ondrop="@(async (DragEventArgs e) => await OnDrop(e, item))">

                                @if (_editingItem == item)
                                {
                                    <div class="item-edit-container">
                                        <div class="item-edit-header">
                                            <input type="text" 
                                                   value="@item.Item.Name" 
                                                   @oninput="@((e) => UpdateItemName(item, e.Value?.ToString()))"
                                                   @onfocus="@(e => SelectAllInputText(e))"
                                                   @ref="itemEditInputElement"
                                                   class="edit-item-input"
                                                   @onkeydown="@(e => HandleItemEditKeyDown(e, item))"
                                                   placeholder="@AppResources.ItemName"
                                                   @onclick:stopPropagation />
                                        </div>

                                        <div class="edit-notes">
                                            <textarea placeholder="@AppResources.AddNotesAboutItem" 
                                                      @bind="item.Item.Notes"
                                                      @bind:event="oninput"
                                                      rows="2"
                                                      class="edit-notes-textarea"
                                                      @onclick:stopPropagation></textarea>
                                        </div>

                                        <div class="item-edit-actions">
                                            <button class="btn secondary btn-sm" @onclick="() => CancelItemEdit(item)" @onclick:stopPropagation title="@AppResources.Cancel">
                                                <i class="fa fa-times"></i> @AppResources.Cancel
                                            </button>
                                            <button class="btn primary btn-sm" @onclick="() => SaveItemChanges(item)" @onclick:stopPropagation title="@AppResources.Save">
                                                <i class="fa fa-check"></i> @AppResources.Save
                                            </button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="item-display" @onclick="() => StartEditingItem(item)" @onclick:stopPropagation>
                                        <span class="item-text">
                                            @item.Item.Name
                                        </span>

                                        @if (!string.IsNullOrWhiteSpace(item.Item.Notes))
                                        {
                                            <div class="notes">
                                                @item.Item.Notes
                                            </div>
                                        }
                                    </div>

                                    <button class="item-delete-btn" 
                                            @onclick="() => PromptDelete(item)"
                                            @onclick:stopPropagation
                                            title="@AppResources.DeleteItemTitle"
                                            aria-label="@string.Format(AppResources.DeleteItemMessage, item.Item.Name)">
                                        <i class="fa fa-trash" aria-hidden="true"></i>
                                    </button>
                                }
                            </li>
                        }
                    </ul>
                </section>

                @* When adding to a specific category, show form right after that category *@
                @if (_isAddingItem && _addingToCategory != null && string.Equals(_addingToCategory, category, StringComparison.OrdinalIgnoreCase))
                {
                    @RenderAddItemForm()
                }
            }

            @* General add (bottom button) or form when no specific category targeted *@
            @if (_isAddingItem && _addingToCategory == null)
            {
                @RenderAddItemForm()
            }
            else if (!_isAddingItem)
            {
                <button class="btn-add-packing-item" @onclick="ShowAddItemForm">
                    <i class="fa fa-plus" aria-hidden="true"></i>
                    <span>@AppResources.AddItem</span>
                </button>
            }
        </div>
    </main>
</div>


@code {
    private RenderFragment RenderAddItemForm() => __builder =>
    {
        <div class="add-item-form" @onclick:stopPropagation>
            <!-- Header with close button -->
            <div class="form-header-inline">
                <h4>@Localizer["AddItems"]</h4>
                <button class="close-form-btn" @onclick="CancelAdd" title="@AppResources.Cancel">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <div class="form-body">
                <!-- Mode Toggle: Quick Add / Bulk Add -->
                <div class="add-mode-toggle">
                    <button type="button" 
                            class="mode-btn @(_isQuickAddMode ? "active" : "")"
                            @onclick="() => SetAddMode(true)">
                        <i class="fa fa-plus"></i>
                        <span>@Localizer["QuickAdd"]</span>
                    </button>
                    <button type="button" 
                            class="mode-btn @(!_isQuickAddMode ? "active" : "")"
                            @onclick="() => SetAddMode(false)">
                        <i class="fa fa-list"></i>
                        <span>@Localizer["BulkAdd"]</span>
                    </button>
                </div>

                <!-- Category Selection (hidden when adding from category header) -->
                @if (!_isCategoryLocked)
                {
                    <div class="form-section compact">
                        <label class="form-label-inline">
                            <i class="fa fa-folder"></i>
                            @AppResources.SelectCategory
                        </label>
                        <div class="custom-dropdown @(_isCategoryDropdownOpen ? "open" : "")" @onclick:stopPropagation>
                            <button type="button" 
                                    class="dropdown-trigger"
                                    @onclick="ToggleCategoryDropdown">
                                <span class="dropdown-selected-text">@GetLocalizedCategoryName(Enum.TryParse<PackingCategory>(_newCategory, out var selectedCat) ? selectedCat : PackingCategory.Miscellaneous)</span>
                                <i class="fa fa-chevron-down dropdown-chevron" aria-hidden="true"></i>
                            </button>
                            @if (_isCategoryDropdownOpen)
                            {
                                <div class="dropdown-menu">
                                    @foreach (var cat in Enum.GetValues<PackingCategory>())
                                    {
                                        var isSelected = _newCategory == cat.ToString();
                                        <button type="button" 
                                                class="dropdown-item @(isSelected ? "selected" : "")"
                                                @onclick="() => SelectCategoryFromDropdown(cat)">
                                            <span>@GetLocalizedCategoryName(cat)</span>
                                            @if (isSelected)
                                            {
                                                <i class="fa fa-check dropdown-item-check" aria-hidden="true"></i>
                                            }
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Input Section -->
                <div class="form-section compact">
                    @if (_isQuickAddMode)
                    {
                        <!-- Quick Add: Single item input -->
                        <label for="quick-add-input" class="form-label-inline">
                            <i class="fa fa-tag"></i>
                            @Localizer["ItemName"]
                        </label>
                        <div class="quick-add-input-container">
                            <input id="quick-add-input"
                                   type="text"
                                   class="quick-add-input"
                                   placeholder="@Localizer["EnterItemNamePlaceholder"]"
                                   @bind="_quickAddText"
                                   @bind:event="oninput"
                                   @bind:after="OnInputChanged"
                                   @ref="quickAddInputRef"
                                   @onkeydown="HandleQuickAddKeyDown" />
                            @if (_isSpeechRecognitionSupported)
                            {
                                <button type="button" 
                                        class="speech-btn-inline @(_isListening ? "listening" : "")" 
                                        @onclick="ToggleSpeechRecognitionQuickAdd"
                                        @onclick:stopPropagation
                                        title="@(_isListening ? AppResources.StopDictation : AppResources.StartDictation)">
                                    <i class="fa @(_isListening ? "fa-stop" : "fa-microphone")" aria-hidden="true"></i>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Bulk Add: Multi-line textarea -->
                        <label for="bulk-textarea" class="form-label-inline">
                            <i class="fa fa-list-ul"></i>
                            @Localizer["EnterItems"]
                        </label>
                        <div class="textarea-container">
                            <textarea id="bulk-textarea"
                                   class="bulk-textarea compact auto-grow" 
                                   placeholder="@GetBulkAddPlaceholder()" 
                                   @bind="_bulkItemsText" 
                                   @bind:event="oninput"
                                   @bind:after="OnBulkTextChanged"
                                   @ref="bulkItemsTextarea"
                                   rows="3"
                                   @onkeydown="HandleBulkTextareaKeyDown"></textarea>

                            @if (_isSpeechRecognitionSupported)
                            {
                                <button type="button" 
                                        class="speech-btn @(_isListening ? "listening" : "")" 
                                        @onclick="ToggleSpeechRecognition"
                                        @onclick:stopPropagation
                                        title="@(_isListening ? AppResources.StopDictation : AppResources.StartDictation)">
                                    <i class="fa @(_isListening ? "fa-stop" : "fa-microphone")" aria-hidden="true"></i>
                                    @if (_isListening)
                                    {
                                        <span class="pulse-ring"></span>
                                    }
                                </button>
                            }
                        </div>
                    }

                    <!-- Autocomplete suggestions -->
                    @if (_suggestions.Count > 0)
                    {
                        <div class="suggestion-chips">
                            @foreach (var suggestion in _suggestions)
                            {
                                <button type="button"
                                        class="suggestion-chip"
                                        @onclick="() => SelectSuggestion(suggestion)"
                                        @onclick:stopPropagation>
                                    <i class="fa fa-plus"></i>
                                    <span>@suggestion</span>
                                </button>
                            }
                        </div>
                    }

                    <!-- Interim transcript for speech -->
                    @if (!string.IsNullOrWhiteSpace(_interimTranscript))
                    {
                        <div class="interim-transcript">
                            <i class="fa fa-microphone"></i>
                            <span>@_interimTranscript</span>
                        </div>
                    }

                    <!-- Listening indicator -->
                    @if (_isListening)
                    {
                        <div class="form-hint-mini listening-hint">
                            <i class="fa fa-microphone"></i>
                            <span>@AppResources.Listening</span>
                        </div>
                    }
                </div>

                <!-- Preview Section -->
                @if (_parsedItems.Count > 0)
                {
                    <div class="preview-section">
                        <div class="preview-header">
                            <span class="preview-title">
                                <i class="fa fa-eye"></i>
                                @Localizer["Preview"] (@_parsedItems.Count @(_parsedItems.Count == 1 ? Localizer["Item"].Value.ToLower() : Localizer["Items"].Value.ToLower()))
                            </span>
                            @if (_duplicateItems.Count > 0)
                            {
                                <span class="duplicate-warning">
                                    <i class="fa fa-exclamation-triangle"></i>
                                    @string.Format(Localizer["DuplicatesRemoved"].Value, _duplicateItems.Count)
                                </span>
                            }
                        </div>
                        <div class="preview-items">
                            @foreach (var previewItem in _parsedItems.Take(10))
                            {
                                var isDuplicate = _existingItemNames.Contains(previewItem.ToLower());
                                <span class="preview-chip @(isDuplicate ? "existing" : "")">
                                    @previewItem
                                    @if (isDuplicate)
                                    {
                                        <i class="fa fa-info-circle" title="@Localizer["ItemAlreadyExists"]"></i>
                                    }
                                </span>
                            }
                            @if (_parsedItems.Count > 10)
                            {
                                <span class="preview-more">+@(_parsedItems.Count - 10) @Localizer["More"].Value.ToLower()</span>
                            }
                        </div>
                    </div>
                }

                <!-- Hints -->
                @if (!_isListening && !HasInput && !_isQuickAddMode)
                {
                    <div class="form-hint-mini">
                        <i class="fa fa-info-circle"></i>
                        <span>@AppResources.BulkAddHint</span>
                    </div>
                }
            </div>

            <!-- Actions -->
            <div class="form-actions compact">
                <button class="btn btn-cancel compact" @onclick="CancelAdd">
                    <i class="fa fa-times"></i>
                    <span>@AppResources.Cancel</span>
                </button>
                <button class="btn btn-primary compact" 
                        @onclick="ConfirmAddAsync" 
                        disabled="@(!CanAdd)">
                    <i class="fa fa-plus"></i>
                    <span>@GetAddButtonText()</span>
                </button>
            </div>
        </div>
    };
}
