@page "/packing-activities"

<div class="page-container with-fixed-navbar">
    @if (_isLoading)
    {
        <div class="loading">
            <div class="loading-spinner"></div>
            <span>@Localizer["Loading"]</span>
        </div>
    }
    else
    {
        <div class="sticky-header">
            <!-- Always visible search bar -->
            <div class="search-bar">
                <i class="fa fa-search search-icon"></i>
                <input type="text" 
                       class="search-input" 
                       placeholder="@Localizer["SearchPlaceholder"]" 
                       @bind="_searchTerm" 
                       @bind:event="oninput" />
                @if (!string.IsNullOrWhiteSpace(_searchTerm))
                {
                    <button class="search-clear-btn" @onclick="ClearSearch">
                        <i class="fa fa-times"></i>
                    </button>
                }
            </div>

            <!-- Filter Bar -->
            <div class="filter-bar">
                <div class="filter-chips">
                    <button class="filter-chip @(_archiveFilter == ArchiveFilterType.Active ? "active" : "")" 
                            @onclick="() => SetArchiveFilter(ArchiveFilterType.Active)">
                        <i class="fa fa-layer-group"></i>
                        <span>@Localizer["Active"]</span>
                    </button>
                    <button class="filter-chip @(_archiveFilter == ArchiveFilterType.Archived ? "active" : "")" 
                            @onclick="() => SetArchiveFilter(ArchiveFilterType.Archived)">
                        <i class="fa fa-archive"></i>
                        <span>@Localizer["Archived"]</span>
                    </button>
                </div>
            </div>
        </div>
        
        @if (FilteredActivities.Any())
        {
            <div class="activities-list">
                @foreach (var activity in FilteredActivities)
                {
                    var itemCount = _activityItemCounts.GetValueOrDefault(activity.Id, 0);
                    
                    <div class="activity-card">
                        <button class="btn-play" 
                                @onclick="() => OpenActivityInPackingMode(activity.Id)"
                                title="@Localizer["PackNow"]">
                            <i class="fa fa-play"></i>
                        </button>
                        
                        <div class="card-header">
                            <div class="header-content">
                                <div class="title-row">
                                    <h3 class="activity-title">@activity.Name</h3>
                                    @if (activity.IsShared)
                                    {
                                        <span class="shared-badge" title="@Localizer["SharedActivity"]">
                                            <i class="fa fa-share-alt"></i>
                                        </span>
                                    }
                                </div>
                                <div class="activity-meta">
                                    <span class="meta-item">
                                        <i class="fa fa-clock"></i>
                                        @GetRelativeTime(activity.LastPacked)
                                    </span>
                                    <span class="meta-separator">•</span>
                                    <span class="meta-item">
                                        <i class="fa fa-box"></i>
                                        @itemCount @GetItemsText()
                                    </span>
                                </div>
                            </div>
                            <div class="card-menu">
                                <button class="btn-menu" 
                                        @onclick="() => ToggleMenuAsync(activity.Id)"
                                        @onclick:stopPropagation
                                        title="@Localizer["More"]">
                                    <i class="fa fa-ellipsis-v"></i>
                                </button>
                                @if (_openMenuId == activity.Id)
                                {
                                    <div class="menu-dropdown">
                                        <button class="menu-item" @onclick="() => OpenActivityInEditMode(activity.Id)">
                                            <i class="fa fa-edit"></i>
                                            <span>@Localizer["Edit"]</span>
                                        </button>
                                        <button class="menu-item" @onclick="() => ToggleArchiveActivity(activity)">
                                            <i class="fa @(activity.IsArchived ? "fa-box-open" : "fa-archive")"></i>
                                            <span>@(activity.IsArchived ? Localizer["Unarchive"] : Localizer["Archive"])</span>
                                        </button>
                                        <button class="menu-item danger" @onclick="() => PromptDeleteActivity(activity)">
                                            <i class="fa fa-trash"></i>
                                            <span>@Localizer["Delete"]</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-activities">
                <div class="empty-icon">
                    <i class="fa fa-luggage-cart"></i>
                </div>
                <h3>@Localizer["NoActivities"]</h3>
                <p>@Localizer["NoActivitiesDescription"]</p>
                <button class="btn primary" @onclick="AddNewActivity">
                    <i class="fa fa-plus"></i> @Localizer["CreateActivity"]
                </button>
            </div>
        }
        
        <!-- Scroll to Top Button -->
        @if (_showScrollToTop)
        {
            <button class="scroll-to-top-fab" @onclick="ScrollToTopAsync" aria-label="Scroll to top" title="Scroll to top">
                <i class="fa fa-arrow-up"></i>
            </button>
        }
        
        <!-- Simplified FAB - Single Add Button -->
        <button class="add-fab" @onclick="AddNewActivity" aria-label="@Localizer["AddActivity"]" title="@Localizer["AddActivity"]">
            <i class="fa fa-plus"></i>
        </button>
    }
</div>

@if (_showAddDialog)
{
    <div class="modal-overlay" @onclick="CancelAddActivity" @onkeydown="HandleDialogKeyDown">
        <div class="modal-content" @onclick:stopPropagation>
            <button class="modal-close-btn" @onclick="CancelAddActivity" aria-label="Close" title="@Localizer["Cancel"]">
                <i class="fa fa-times"></i>
            </button>
            
            <div class="modal-icon">
                <i class="fa fa-plus-circle"></i>
            </div>
            
            <h4 class="modal-header">@Localizer["NewPackingActivity"]</h4>
            
            <div class="form-row">
                <label for="activity-name">@Localizer["Name"]</label>
                <input id="activity-name" 
                       type="text"
                       class="@(string.IsNullOrWhiteSpace(_newActivityName) && _hasAttemptedSubmit ? "input-error" : "")"
                       placeholder="@Localizer["EnterActivityName"]"
                       @bind="_newActivityName" 
                       @bind:event="oninput"
                       @onkeydown="HandleInputKeyDown"
                       @ref="_activityNameInput" />
                @if (string.IsNullOrWhiteSpace(_newActivityName) && _hasAttemptedSubmit)
                {
                    <span class="error-message">
                        <i class="fa fa-exclamation-circle"></i>
                        @Localizer["NameRequired"]
                    </span>
                }
            </div>
            
            <div class="form-row">
                <label>@Localizer["ActivityType"]</label>
                <div class="radio-group">
                    <label class="radio-option" @onclick="() => _isRecurringActivity = false">
                        <input type="radio" 
                               name="activity-type" 
                               value="one-time" 
                               checked="@(!_isRecurringActivity)" />
                        <span class="radio-label">
                            <i class="fa fa-calendar-check"></i>
                            <div>
                                <strong>@Localizer["OneTimeActivity"]</strong>
                                <small>@Localizer["OneTimeActivityDescription"]</small>
                            </div>
                        </span>
                    </label>
                    <label class="radio-option" @onclick="() => _isRecurringActivity = true">
                        <input type="radio" 
                               name="activity-type" 
                               value="recurring" 
                               checked="@_isRecurringActivity" />
                        <span class="radio-label">
                            <i class="fa fa-sync-alt"></i>
                            <div>
                                <strong>@Localizer["RecurringActivity"]</strong>
                                <small>@Localizer["RecurringActivityDescription"]</small>
                            </div>
                        </span>
                    </label>

                </div>
            </div>

            <div class="form-actions">
                <button class="btn cancel" @onclick="CancelAddActivity" disabled="@_isCreating">
                    @Localizer["Cancel"]
                </button>
                <button class="btn primary" 
                        @onclick="ConfirmAddActivityAsync" 
                        disabled="@(_isCreating || string.IsNullOrWhiteSpace(_newActivityName))">
                    @if (_isCreating)
                    {
                        <span class="btn-spinner"></span>
                        <span>@Localizer["Creating"]</span>
                    }
                    else
                    {
                        <i class="fa fa-check"></i>
                        <span>@Localizer["Create"]</span>
                    }
                </button>
            </div>
        </div>
    </div>
}